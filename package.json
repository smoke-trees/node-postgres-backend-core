{
  "name": "@smoke-trees/postgres-backend",
  "version": "3.1.0",
  "description": "Postgres Backend Core files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "test": "NODE_OPTIONS=--enable-source-maps mocha --exit --file dist/tests/index.test.js",
    "test-w": "set NODE_OPTIONS=--enable-source-maps && set CI=true && mocha --exit dist/tests/index.test.js",
    "watch": "tsc -w",
    "dev": "NODE_OPTIONS=--enable-source-maps nodemon -L -w ./dist -w ./src -w docs/build/docs.yaml dist/Example/index.js",
    "prepare": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoke-trees/node-postgres-backend-core.git"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "postgres"
  ],
  "author": "SmokeTrees",
  "license": "MIT",
  "homepage": "https://github.com/smoke-trees/node-postgres-backend-core#readme",
  "eslintConfig": {
    "rules": {
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": "error"
    }
  },
  "dependencies": {
    "@smoke-trees/smoke-context": "^1.5.4",
    "@types/chai": "^4.3.20",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/express-serve-static-core": "^4.19.6",
    "@types/lodash.set": "^4.3.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.9",
    "@types/qs": "^6.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "lodash.set": "^4.3.2",
    "pg": "^8.16.3",
    "qs": "^6.14.0",
    "typeorm": "0.3.20",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "chai": "^4.5.0",
    "chai-http": "^4.4.0",
    "eslint": "^9.32.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "mocha": "^10.8.2",
    "nodemon": "^3.1.10",
    "typescript": "5.4.3"
  }
}
